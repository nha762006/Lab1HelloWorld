<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1C1C1C"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:padding="20dp"
        android:text="Xin chào, tôi tên là Nguyễn Hoàng Anh"
        android:textColor="#FFFFFF"
        android:textSize="30sp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4">

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#D4D4D2"
            android:insetLeft="1dp"
            android:insetTop="1dp"
            android:insetRight="1dp"
            android:insetBottom="1dp"
            android:text="AC"
            android:onClick="onClearClick"
            android:textColor="#000000" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#D4D4D2"
            android:insetLeft="1dp"
            android:insetTop="1dp"
            android:insetRight="1dp"
            android:insetBottom="1dp"
            android:text="+/-"
            android:textColor="#000000" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#D4D4D2"
            android:insetLeft="1dp"
            android:insetTop="1dp"
            android:insetRight="1dp"
            android:insetBottom="1dp"
            android:text="%"
            android:textColor="#000000" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#FF9F0A"
            android:insetLeft="1dp"
            android:insetTop="1dp"
            android:insetRight="1dp"
            android:insetBottom="1dp"
            android:text="÷"
            android:onClick="onOperatorClick"
            android:textColor="#FFFFFF" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#505050"
            android:text="7"
            android:onClick="onNumberClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#505050"
            android:text="8"
            android:onClick="onNumberClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#505050"
            android:text="9"
            android:onClick="onNumberClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#FF9F0A"
            android:text="×"
            android:onClick="onOperatorClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#505050"
            android:text="4"
            android:onClick="onNumberClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#505050"
            android:text="5"
            android:onClick="onNumberClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#505050"
            android:text="6"
            android:onClick="onNumberClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#FF9F0A"
            android:text="-"
            android:onClick="onOperatorClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#505050"
            android:text="1"
            android:onClick="onNumberClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#505050"
            android:text="2"
            android:onClick="onNumberClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#505050"
            android:text="3"
            android:onClick="onNumberClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#FF9F0A"
            android:text="+"
            android:onClick="onOperatorClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnSpan="2"
            android:layout_columnWeight="1"
            android:layout_gravity="fill_horizontal"
            android:backgroundTint="#505050"
            android:text="0"
            android:onClick="onNumberClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#505050"
            android:text="."
            android:onClick="onNumberClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#FF9F0A"
            android:text="="
            android:onClick="onEqualClick"
            android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp" />

    </GridLayout>
</LinearLayout>